{
  "manifest_version": 3,
  "name": "Pants",
  "version": "1.0",
  "description": "Hides the Shorts shelf and Shorts nav entry on YouTube.",
  "browser_specific_settings": {
    "gecko": { "id": "pants@evanbarrycontact.dev" }
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "css": ["src/hide.css"],
      "js": ["src/selectors.js", "src/observer.js"],
      "run_at": "document_start"
    }
  ]
}
